# Postgres (used by docker-compose.yml and the backend's DATABASE_URL)
POSTGRES_USER=narrative
POSTGRES_PASSWORD=narrative
POSTGRES_DB=narrative_clustering
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://narrative:narrative@localhost:5432/narrative_clustering

# Embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Clerk auth (backend). Create a free app at https://dashboard.clerk.com,
# then set this to https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
# (find the exact URL under Configure > API Keys > Show JWKS URL).
# Until this is set, sign-in is inert but all public routes work normally.
CLERK_JWKS_URL=
