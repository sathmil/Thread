# Postgres (used by docker-compose.yml and the backend's DATABASE_URL)
POSTGRES_USER=narrative
POSTGRES_PASSWORD=narrative
POSTGRES_DB=narrative_clustering
POSTGRES_PORT=5432
DATABASE_URL=postgresql://narrative:narrative@localhost:5432/narrative_clustering

# Embeddings
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
